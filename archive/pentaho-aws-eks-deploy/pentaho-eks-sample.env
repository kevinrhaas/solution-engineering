# =============================================================================
# Pentaho AWS EKS Deployment Configuration - SAMPLE TEMPLATE
# =============================================================================
# INSTRUCTIONS: 
# 1. Copy this file to create your environment-specific configuration:
#    cp pentaho-eks-sample.env pentaho-eks-dev.env
#    cp pentaho-eks-sample.env pentaho-eks-test.env  
#    cp pentaho-eks-sample.env pentaho-eks-prod.env
# 2. Update the copied file with your actual values
# 3. Never commit the actual environment files to Git (they're in .gitignore)

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
ENVIRONMENT=sample

# AWS Configuration
AWS_REGION=us-west-2
AWS_PROFILE=khaas

# SSH Key Configuration for EC2 worker node access
# This should match the key pair name in AWS EC2
KEY_PATH=/Users/khaas/.ssh/pentaho+_se_keypair.pem

# =============================================================================
# AWS INFRASTRUCTURE CONFIGURATION
# =============================================================================

# EKS Cluster Configuration
CLUSTER_NAME=pentaho-eks-cluster
KUBERNETES_VERSION=1.28
NODE_GROUP_NAME=pentaho-workers
NODE_INSTANCE_TYPE=t3.large
NODE_DESIRED_CAPACITY=2
NODE_MIN_SIZE=1
NODE_MAX_SIZE=4

# RDS PostgreSQL Configuration
DB_INSTANCE_IDENTIFIER=pentaho-postgres
DB_INSTANCE_CLASS=db.t3.medium
DB_ENGINE_VERSION=15.4
DB_ALLOCATED_STORAGE=100
DB_STORAGE_TYPE=gp3
DB_USERNAME=postgres
DB_PASSWORD=your-secure-password
DB_PORT=5432

# S3 Configuration
S3_BUCKET_NAME=pentaho-eks-storage
S3_REGION=us-west-2
S3_SOFTWARE_OVERRIDE_PREFIX=database/softwareOverride

# ECR Configuration  
ECR_REPOSITORY_NAME=pentaho-server
ECR_REGION=us-west-2
ECR_ACCOUNT_ID=524647911006

# Hitachi Vantara Artifactory Configuration
# Generate token at: https://one.hitachivantara.com/ui/native/pntprv-generic-dev/pentaho/pdia-image-configurator/
# Set as environment variable: export HITACHI_ARTIFACTORY_TOKEN=your-token-here
HITACHI_ARTIFACTORY_TOKEN=REDACTED_JFROG_TOKEN
HV_DOCKER_REGISTRY=registry.hitachivantara.com
JFROG_DOCKER_REGISTRY=hitachivantara.jfrog.io

# =============================================================================
# PENTAHO APPLICATION CONFIGURATION
# =============================================================================

# Pentaho Version
PENTAHO_VERSION=11.0.0.0-xxx
PENTAHO_IMAGE_NAME=pentaho-server
PENTAHO_NAMESPACE=pentaho-server

# Docker Registry Configuration
HV_DOCKER_REGISTRY=one.hitachivantara.com
JFROG_DOCKER_REGISTRY=pntprv-docker-dev

# Application Resources
PENTAHO_CPU_REQUEST=1000m
PENTAHO_CPU_LIMIT=2000m
PENTAHO_MEMORY_REQUEST=4Gi
PENTAHO_MEMORY_LIMIT=8Gi

# Storage Configuration
STORAGE_CLASS=gp3-csi
PVC_SIZE=20Gi

# =============================================================================
# NETWORKING CONFIGURATION
# =============================================================================

# VPC and Security Configuration  
VPC_ID=vpc-095f761a169c10b8e
SUBNET_ID=subnet-059321ee33ee549e7
SECURITY_GROUP_ID=sg-020200447994fa148

# Load Balancer Configuration
LOAD_BALANCER_TYPE=application
LOAD_BALANCER_SCHEME=internet-facing

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================

# SSL Certificate (for HTTPS access)
SSL_CERTIFICATE_ARN=
DOMAIN_NAME=pentaho.yourdomain.com

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

# CloudWatch Configuration
ENABLE_CLOUDWATCH_LOGS=true
LOG_GROUP_NAME=/aws/eks/pentaho-server
LOG_RETENTION_DAYS=30

# Metrics Configuration
ENABLE_PROMETHEUS=true
ENABLE_GRAFANA=true

# =============================================================================
# BACKUP AND MAINTENANCE
# =============================================================================

# Backup Configuration
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Maintenance Window
MAINTENANCE_WINDOW="sun:03:00-sun:04:00"

# =============================================================================
# DEVELOPMENT/TESTING OPTIONS
# =============================================================================

# Development Mode (enables additional logging and tools)
DEV_MODE=false

# Skip SSL verification (for development only)
SKIP_SSL_VERIFY=false

# Enable debug mode
DEBUG=false
