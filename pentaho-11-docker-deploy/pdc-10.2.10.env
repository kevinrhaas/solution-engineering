# ================================================================================================
# PENTAHO DATA CATALOG (PDC) DOCKER DEPLOYMENT - SAMPLE CONFIGURATION
# ================================================================================================
# This sample contains working values for deploying PDC via Docker Compose.
# Ready to deploy after updating the ⚠️ REQUIRED values with your specific details.
#
# To create your own environment:
#   1. Copy this file: cp pdc-10.2.10.env pdc-yourenv.env
#   2. Update values marked with ⚠️ REQUIRED (credentials, network IDs, license)
#   3. Optionally customize values marked with ℹ️ OPTIONAL
#   4. Deploy: ./00-full-deploy-pdc.sh pdc-yourenv.env
# ================================================================================================

# ================================================================================================
# AWS AUTHENTICATION
# ================================================================================================

# ⚠️ REQUIRED: AWS CLI profile name (must be configured in ~/.aws/credentials)
AWS_PROFILE=khaas

# ℹ️ OPTIONAL: AWS region (default: us-west-2)
AWS_REGION=us-west-2

# ================================
# SSH KEY CONFIGURATION
# ================================
# ⚠️ REQUIRED: Your AWS EC2 key pair name (must exist in AWS)
KEY_NAME=pentaho+_se_keypair

# ⚠️ REQUIRED: Full path to your SSH private key file
KEY_PATH=$HOME/.ssh/pentaho+_se_keypair.pem

# DEFAULT: SSH user for Ubuntu AMI (don't change)
SSH_USER=ubuntu

# ================================
# INSTANCE CONFIGURATION
# ================================
# DEFAULT: Project name for tagging
PROJECT_NAME=pdc-docker

# ⚠️ REQUIRED: Unique name for this instance
INSTANCE_NAME=${PROJECT_NAME}

# DEFAULT: Ubuntu 22.04 LTS AMI for us-west-2 (don't change unless using different region)
AMI_ID=ami-0d70546e43a941d70

# ℹ️ OPTIONAL: EBS volume size in GB (PDC needs more storage for OpenSearch data)
EBS_VOLUME_SIZE=200

# DEFAULT: Volume type (gp3 is latest generation)
VOLUME_TYPE=gp3

# ℹ️ OPTIONAL: Instance type
# PDC runs multiple services (OpenSearch, PostgreSQL, Keycloak, frontend, etc.)
# Minimum recommended: r7i.xlarge (4 vCPU, 32GB RAM)
INSTANCE_TYPE=r7i.xlarge

# ================================
# PDC VERSION & ARTIFACTS
# ================================
# ⚠️ REQUIRED: PDC version
PDC_VERSION=10.2.10

# ⚠️ REQUIRED: Exact compose-bundle filename from JFrog (browse release-v{VERSION}/ to find it)
#    JFrog: https://one.hitachivantara.com/ui/native/pdc-generic-dev/pentaho/pdc-docker-deployment/release-v10.2.10/
#    Pick the latest *-compose.tgz file and paste the full filename here.
PDC_ARTIFACT=pdc-full-release-v10.2.10-260313103138-cc2b46d-compose.tgz

# ⚠️ REQUIRED: Environment identifier (used for tracking)
ENVIRONMENT=pdc-10.2.10

# ================================
# JFROG CONFIGURATION
# ================================
# ⚠️ REQUIRED: JFrog username (your corporate login, e.g. first.last@hitachivantara.com)
JFROG_USER=kevin.haas@hitachivantara.com

# ⚠️ REQUIRED: JFrog access token (get from: https://one.hitachivantara.com/ → Set Me Up)
JFROG_TOKEN=REDACTED_JFROG_TOKEN

# ℹ️ OPTIONAL: JFrog base URL for PDC artifacts
PDC_JFROG_BASE_URL=https://one.hitachivantara.com/artifactory/pdc-generic-dev/pentaho/pdc-docker-deployment

# ================================
# PDC CONFIGURATION
# ================================
# ⚠️ REQUIRED: PDC license server URL
PDC_LICENSE_URL=https://pentaho-uat.compliance.flexnetoperations.com/instances/M70ZF9BDB2DX/request

# ℹ️ OPTIONAL: Allowed email domains for PDC user registration (JSON array format)
EMAIL_DOMAINS='["hv.com", "hitachivantara.com"]'

# ================================
# NETWORK CONFIGURATION
# ================================
# ⚠️ REQUIRED: Your VPC ID (format: vpc-xxxxxxxxxxxxx)
VPC_ID=vpc-095f761a169c10b8e

# ⚠️ REQUIRED: Your subnet ID (format: subnet-xxxxxxxxxxxxx)
SUBNET_ID=subnet-059321ee33ee549e7

# ⚠️ REQUIRED: Your security group ID (format: sg-xxxxxxxxxxxxx)
# Security group must allow:
#   - Inbound: SSH (22), HTTPS (443)
#   - Outbound: HTTPS (443) for license servers, JFrog
SECURITY_GROUP_ID=sg-020200447994fa148

# ================================
# DATABASE CONFIGURATION
# ================================
# PDC uses PostgreSQL (bidb) — this is fixed, not configurable
DB_TYPE=postgres

# ================================
# PDC MIGRATION (SOURCE -> TARGET)
# ================================
# Optional values used by 40-migrate-pdc.sh for recurring migrations.
# Source and target IPs are intentionally NOT stored in env file.
# Pass them at runtime with:
#   --source-ip <ip> --target-ip <ip>

# Optional per-host SSH overrides (defaults to SSH_USER / KEY_PATH)
# PDC_MIGRATION_SOURCE_SSH_USER=ubuntu
# PDC_MIGRATION_TARGET_SSH_USER=ubuntu
# PDC_MIGRATION_SOURCE_KEY_PATH=$HOME/.ssh/pentaho+_se_keypair.pem
# PDC_MIGRATION_TARGET_KEY_PATH=$HOME/.ssh/pentaho+_se_keypair.pem

# Optional local working directory for migration bundle staging
# PDC_MIGRATION_WORK_DIR=$PWD/generatedFiles/pdc-migrations
