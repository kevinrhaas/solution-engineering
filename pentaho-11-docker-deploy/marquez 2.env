# ================================================================================================
# MARQUEZ OPENLINEAGE SERVER - DEPLOYMENT CONFIGURATION
# ================================================================================================
# Marquez is an OpenLineage-compatible metadata server.
# Deploy flow:
#   1. ./02-create-ec2.sh marquez.env          — provision EC2
#   2. ./03-check-ec2.sh marquez.env           — wait for readiness
#   3. ./50-deploy-marquez.sh marquez.env      — install & start Marquez
#   4. ./51-test-marquez.sh marquez.env        — verify connectivity
# ================================================================================================

# ================================
# AWS AUTHENTICATION
# ================================
AWS_PROFILE=khaas
AWS_REGION=us-west-2

# ================================
# SSH KEY CONFIGURATION
# ================================
KEY_NAME=pentaho+_se_keypair
KEY_PATH=$HOME/.ssh/pentaho+_se_keypair.pem
SSH_USER=ubuntu

# ================================
# INSTANCE CONFIGURATION
# ================================
PROJECT_NAME=marquez
INSTANCE_NAME=marquez-openlineage
ENVIRONMENT=marquez

# Ubuntu 22.04 LTS AMI for us-west-2
AMI_ID=ami-0d70546e43a941d70

# t3.small: 2 vCPU, 2GB RAM — sufficient for Marquez + Postgres
INSTANCE_TYPE=t3.small

EBS_VOLUME_SIZE=30
VOLUME_TYPE=gp3

# ================================
# NETWORK CONFIGURATION
# ================================
# Same VPC/subnet/SG as Pentaho — all-open SG allows intra-VPC traffic
VPC_ID=vpc-095f761a169c10b8e
SUBNET_ID=subnet-059321ee33ee549e7
SECURITY_GROUP_ID=sg-020200447994fa148

# ================================
# MARQUEZ CONFIGURATION
# ================================
# Port Marquez API listens on (OpenLineage events go here)
MARQUEZ_API_PORT=5000
# Port Marquez admin/health endpoint
MARQUEZ_ADMIN_PORT=5001
# Port Marquez web UI
MARQUEZ_WEB_PORT=80

MARQUEZ_DB_USER=marquez
MARQUEZ_DB_PASSWORD=marquez
MARQUEZ_DB_NAME=marquez

# ================================
# PENTAHO RESOURCE LIMITS
# ================================
# Kept minimal — Marquez is lightweight
PENTAHO_CONTAINER_CPU_LIMIT=1.8
PENTAHO_CONTAINER_MEMORY_LIMIT=5.5GB
DATABASE_CONTAINER_CPU_LIMIT=0.2
DATABASE_CONTAINER_MEMORY_LIMIT=1.5GB
PENTAHO_JVM_MIN_HEAP=1g
PENTAHO_JVM_MAX_HEAP=3g
