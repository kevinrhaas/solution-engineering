        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>var newPrompt = prompt;
newPrompt = newPrompt.split("${PLATFORM}").join(platform);
newPrompt = newPrompt.split("${TABLE}").join(table_name);
newPrompt = newPrompt.split("${DOMAIN}").join(domain);
newPrompt = newPrompt.split("${INDUSTRY}").join(industry);
newPrompt = newPrompt.split("${FIELDS}").join(full_json);
newPrompt = newPrompt.split("${DEPNOTE}").join(dep_note);
newPrompt = newPrompt.split("${NUM_RECORDS}").join(num_recs);

// newPrompt = newPrompt + ddl;

// var request = '{"model": "' + model + '", "input": "' + newPrompt + '"}';


var request = JSON.stringify({
  model: model,
  input: newPrompt
});
</jsScript_script>
      </jsScript>
