        <jsScript_script>//Script here

var formattedText = text
  .replace("```sql", "")
  .replace("```", "");

var padded_order = load_order.padStart(3, '0');  // => "001"

// only replace the end extension
var filenameOut = filenamepath + '/temp/' + padded_order + '-' + table + '.ddl';


</jsScript_script>
