    <connection>gen_ai</connection>
    <sql>SELECT
json_build_object(
  'messages', json_build_array(json_build_object(
    'role', 'user',
    'content', replace(prompt, '{{CONTACTVOLUME}}', '${CONTACTVOLUME}')
  ))) AS request_raw, prompt_name, prompt_id
FROM gen_ai.prompt_library
WHERE prompt_type = 'lead-list-generation-2';
