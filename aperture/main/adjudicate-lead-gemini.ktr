    <connection>gen_ai</connection>
    <sql>SELECT 
  prompt_id,
  json_build_object(
    'contents', json_build_array(
      json_build_object(
        'parts', json_build_array(
          json_build_object(
            'text', replace(prompt, '{{CONTEXT}}', '${CONTEXT}')
          )
        )
      )
    ),
    'tools', json_build_array(
      json_build_object(
        'googleSearch', json_build_object()   -- use defaults
      )
    )
  ) AS request_raw
FROM gen_ai.prompt_library
WHERE prompt_id in (${PROMPT_ID});
</sql>
