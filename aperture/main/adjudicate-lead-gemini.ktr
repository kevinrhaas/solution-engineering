  <step>
    <name>Get Leads</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>gen_ai</connection>
    <sql>WITH adj_counts AS (
    SELECT
        a.fuzzy_match_org_site_contact_key,
        COUNT(*) AS run_count
    FROM gen_ai.adj_lead_generation a
    WHERE a.prompt_id = ${PROMPT_ID}          -- only count adjudications for this prompt
    GROUP BY
        a.fuzzy_match_org_site_contact_key
),
raw_with_len AS (
    SELECT
        r.*,
        COALESCE(ac.run_count, 0) AS run_count,
        -- length driver for selecting canonical row
        length(COALESCE(r.org_name, '')) +
        length(COALESCE(r.org_site_location, '')) +
        length(COALESCE(r.contact_name, '')) AS name_len
    FROM gen_ai.raw_lead_generation r
    LEFT JOIN adj_counts ac
        ON ac.fuzzy_match_org_site_contact_key = r.fuzzy_match_org_site_contact_key
    WHERE
        r.contact_name          IS NOT NULL
        AND r.org_name          IS NOT NULL
        AND r.org_site_location IS NOT NULL
         -- threshold: allow counts strictly below PROMPT_ID_COUNT_ALLOWED
        AND COALESCE(ac.run_count, 0) &lt; ${PROMPT_ID_COUNT_ALLOWED}
)        
SELECT
    rw.fuzzy_match_org_site_contact_key,
    -- canonical values from the row w/ longest combined text
    (ARRAY_AGG(rw.org_name          ORDER BY rw.name_len DESC))[1] AS org_name,
    (ARRAY_AGG(rw.org_site_location ORDER BY rw.name_len DESC))[1] AS org_site_location,
    (ARRAY_AGG(rw.contact_name      ORDER BY rw.name_len DESC))[1] AS contact_name,
    -- 🔹 DISTINCT comma-separated lists for the fuzzy group
    STRING_AGG(DISTINCT rw.contact_role,          ', ' ORDER BY rw.contact_role)          AS contact_role,
    STRING_AGG(DISTINCT rw.contact_email_address, ', ' ORDER BY rw.contact_email_address) AS contact_email_address,
    STRING_AGG(DISTINCT rw.contact_phone,         ', ' ORDER BY rw.contact_phone)         AS contact_phone,
    -- ID of the chosen "longest" raw row
    (ARRAY_AGG(rw.lead_generation_id ORDER BY rw.name_len DESC))[1]
        AS canonical_lead_generation_id,
    -- arrays across the group
    ARRAY_AGG(DISTINCT rw.lead_generation_id ORDER BY rw.lead_generation_id) AS lead_generation_id_array,
    ARRAY_AGG(DISTINCT rw.prompt_id         ORDER BY rw.prompt_id)           AS prompt_id_array,
    MAX(rw.run_count) AS run_count
FROM raw_with_len rw
GROUP BY
    rw.fuzzy_match_org_site_contact_key</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>Y</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <cached_row_meta_active>N</cached_row_meta_active>
