  <step>
    <name>get raw salesforce</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>gen_ai</connection>
    <sql> 
SELECT
    coalesce(src.account_id, src.contact_id) salesforce_org_site_contact_role_id,
    src.account_id salesforce_acct_id,
    src.account_name org_name,
    src.account_type org_type,
    src.active_subscription org_active_sub,
    src.billing_city || ', ' || src.billing_state || ', ' || src.billing_country org_site_location,
    src.billing_city org_site_city,
    src.billing_state org_site_state,
    src.billing_country org_site_country,
    src.contact_id salesforce_contact_id,
    src.title contact_role,
    src.first_name  contact_first_name,
    src.last_name contact_last_name,
    src.first_name || ' ' || src.last_name contact_name,
    LOWER(REPLACE(src.email, ' ', '')) AS contact_email, -- normalize
    src.phone contact_phone,
    NOW() current_datetime
FROM gen_ai.raw_salesforce_acct_baddr_contact_title AS src</sql>
