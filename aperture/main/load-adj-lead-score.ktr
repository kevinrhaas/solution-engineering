  <step>
    <name>Calculate Scores</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>gen_ai</connection>
    <sql>with base as (
  select
      alg.fuzzy_match_org_site_contact_key,
      sum(case when alg.is_human = 'Y' then 1 else 0 end)                      as is_human_cnt,
      sum(case when alg.is_human_in_role = 'Y' then 1 else 0 end)              as is_human_in_role_cnt,
      count(*)                                                                 as num_of_adjudications,
      max(alg.is_human_confidence_score)                                       as max_is_human_confidence_score,
      max(alg.is_human_in_role_confidence_score)                               as max_is_human_in_role_confidence_score
  from gen_ai.adj_lead_generation alg
  where alg.fuzzy_match_org_site_contact_key is not null
  group by 1
),
canon_counts as (
  select
    alg.fuzzy_match_org_site_contact_key,
    alg.canonical_lead_generation_id,
    count(*) as canonical_id_cnt
  from gen_ai.adj_lead_generation alg
  where alg.fuzzy_match_org_site_contact_key is not null
    and alg.canonical_lead_generation_id is not null
  group by 1,2
),
canon_ranked as (
  select
    cc.*,
    row_number() over (
      partition by cc.fuzzy_match_org_site_contact_key
      order by cc.canonical_id_cnt desc, cc.canonical_lead_generation_id asc
    ) as rn
  from canon_counts cc
),
canon_pick as (
  select
    cr.fuzzy_match_org_site_contact_key,
    cr.canonical_lead_generation_id as canonical_lead_generation_id_mode,
    cr.canonical_id_cnt             as canonical_lead_generation_id_mode_cnt
  from canon_ranked cr
  where cr.rn = 1
),
canon_fallback as (
  -- deterministic “first” backup; if you have created_at, replace with the earliest-by-time selection
  select
    alg.fuzzy_match_org_site_contact_key,
    min(alg.canonical_lead_generation_id) as canonical_lead_generation_id_first
  from gen_ai.adj_lead_generation alg
  where alg.fuzzy_match_org_site_contact_key is not null
    and alg.canonical_lead_generation_id is not null
  group by 1
),
norm as (
  select
    b.*,
    cp.canonical_lead_generation_id_mode,
    cp.canonical_lead_generation_id_mode_cnt,
    cf.canonical_lead_generation_id_first,
    ln(1 + b.is_human_cnt)           as l_human_cnt,
    ln(1 + b.is_human_in_role_cnt)   as l_role_cnt,
    ln(1 + b.num_of_adjudications)   as l_adj_cnt,
    min(ln(1 + b.is_human_cnt))         over () as min_l_human_cnt,
    max(ln(1 + b.is_human_cnt))         over () as max_l_human_cnt,
    min(ln(1 + b.is_human_in_role_cnt)) over () as min_l_role_cnt,
    max(ln(1 + b.is_human_in_role_cnt)) over () as max_l_role_cnt,
    min(ln(1 + b.num_of_adjudications)) over () as min_l_adj_cnt,
    max(ln(1 + b.num_of_adjudications)) over () as max_l_adj_cnt
  from base b
  left join canon_pick cp
    on cp.fuzzy_match_org_site_contact_key = b.fuzzy_match_org_site_contact_key
  left join canon_fallback cf
    on cf.fuzzy_match_org_site_contact_key = b.fuzzy_match_org_site_contact_key
)
select
  n.*,
  (
    100.0 * (
      0.30 * (n.max_is_human_confidence_score::integer / 100.0) +
      0.35 * (n.max_is_human_in_role_confidence_score::integer / 100.0) +
      0.15 * (case when n.max_l_human_cnt = n.min_l_human_cnt then 0
                   else (n.l_human_cnt - n.min_l_human_cnt) / (n.max_l_human_cnt - n.min_l_human_cnt) end) +
      0.15 * (case when n.max_l_role_cnt = n.min_l_role_cnt then 0
                   else (n.l_role_cnt - n.min_l_role_cnt) / (n.max_l_role_cnt - n.min_l_role_cnt) end) +
      0.05 * (case when n.max_l_adj_cnt = n.min_l_adj_cnt then 0
                   else (n.l_adj_cnt - n.min_l_adj_cnt) / (n.max_l_adj_cnt - n.min_l_adj_cnt) end) +
      0.08 * (
        (n.max_is_human_confidence_score::integer / 100.0) *
        (n.max_is_human_in_role_confidence_score::integer / 100.0)
      )
    )
  ) as target_score
from norm n
order by
  target_score desc,
  n.canonical_lead_generation_id_first asc,   -- backup selection sort
  n.is_human_in_role_cnt desc,
  n.is_human_cnt desc;</sql>
