        <jsScript_script>//Script here

decr_password=Packages.org.pentaho.di.core.encryption.Encr.decryptPasswordOptionallyEncrypted(password);

value = 'client_id=' + encodeURIComponent(client_id)
	  + '&amp;grant_type=' + encodeURIComponent(grant_type) 
	  + '&amp;username=' + encodeURIComponent(username)
	  + '&amp;password=' + encodeURIComponent(decr_password) 
	  + '&amp;scope=' + encodeURIComponent(scope);





</jsScript_script>
