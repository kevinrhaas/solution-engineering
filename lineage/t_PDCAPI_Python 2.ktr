      <group name="">
        <property group="" name="SCRIPT">
          <value xsi:type="xs:string"># python script

import warnings
import requests
from urllib3.exceptions import InsecureRequestWarning

# Suppress only the single InsecureRequestWarning from urllib3 needed
warnings.simplefilter('ignore', InsecureRequestWarning)

def generate_bearer_token(auth_url, username, password, client_id, scope="openid"):
    """
    Generates a bearer token from the authentication endpoint.
    """
    headers = {
        "Content-Type": "application/x-www-form-urlencoded"
    }
    data = {
        "username": username,
        "password": password,
        "grant_type": "password",
        "client_id": client_id,
        "scope": scope
    }
    
    response = requests.post(auth_url, data=data, headers=headers, verify=False)
    
    if response.status_code == 200:
        # Parse and return the token from the response
        return response.json().get("access_token")
    else:
        response.raise_for_status()

def delete_request_graphql(endpoint_url, bearer_token, item_id):
    """
    Sends a DELETE request to the GraphQL endpoint with the generated bearer token.
    """
    headers = {
        "Authorization": f"Bearer {bearer_token}",
        "Content-Type": "application/json"
    }
    
  # GraphQL mutation query structure with specified input format
    payload = {
        "operationName": "deleteProperty",
        "variables": {
            "id": item_id
        },
        "query": """
            mutation deleteProperty($id: MongoID!) {
                CustomPropertyRemoveById(_id: $id) {
                    record {
                        _id
                        __typename
                    }
                    __typename
                }
            }
        """
    }
    
    # Print the payload for debugging
    print("Payload:", payload)

    # Make the POST request to the GraphQL endpoint
    response = requests.post(endpoint_url, json=payload, headers=headers, verify=False)
    
    # Check response status and return JSON if successful, else raise an error
    if response.status_code == 200:
        return response.json()  # Parse the JSON response
    else:
        response.raise_for_status()

