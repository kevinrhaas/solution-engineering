    bearer_token = generate_bearer_token(auth_url, username, password, client_id)
    print("Generated Bearer Token:", bearer_token)
    
    # Step 2: Use the token to make the DELETE Custom Property request
    result = delete_request_graphql(endpoint_url, bearer_token, item_id)
    print("Delete Response:", result)
