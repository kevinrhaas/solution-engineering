# =============================================================================
# Pentaho Docker Deployment Configuration - SAMPLE TEMPLATE
# =============================================================================
# INSTRUCTIONS: 
# 1. Copy this file to create your environment-specific configuration:
#    cp pentaho-deployment-sample.env pentaho-deployment-dev.env
#    cp pentaho-deployment-sample.env pentaho-deployment-test.env  
#    cp pentaho-deployment-sample.env pentaho-deployment-prod.env
# 2. Update the copied file with your actual values
# 3. Never commit the actual environment files to Git (they're in .gitignore)
# Generated: Sample Template
KEY_PATH=/Users/khaas/.ssh/pentaho+_se_keypair.pem
ENVIRONMENT=sample
AWS_REGION=us-west-2
AWS_PROFILE=khaas

# AWS Infrastructure Configuration
KEY_NAME=pentaho+_se_keypair
SSH_USER=ubuntu  # ec2-user for Amazon Linux AMI, ubuntu for Ubuntu AMI
INSTANCE_TYPE=t3.large
AMI_ID=ami-0d70546e43a941d70  # Ubuntu 22.04 LTS AMI (us-west-2)
EBS_VOLUME_SIZE=75
VOLUME_TYPE=gp3
PROJECT_NAME=pentaho-docker

# VPC and Security Configuration  
VPC_ID=vpc-095f761a169c10b8e
SUBNET_ID=subnet-059321ee33ee549e7
SECURITY_GROUP_ID=sg-020200447994fa148

# Container Resource Limits (for t3.large compatibility)
CONTAINER_CPU_LIMIT=1.5
CONTAINER_MEMORY_LIMIT=3GB
