&gt;NATIVE&lt;/org.pentaho.database.model.DatabaseAccessType&gt;&#xA;        &lt;org.pentaho.database.model.DatabaseAccessType&gt;JNDI&lt;/org.pentaho.database.model.DatabaseAccessType&gt;&#xA;      &lt;/supportedAccessTypes&gt;&#xA;      &lt;extraOptionsHelpUrl&gt;http://jdbc.postgresql.org/documentation/83/connect.html#connection-parameters&lt;/extraOptionsHelpUrl&gt;&#xA;    &lt;/databaseType&gt;&#xA;    &lt;extraOptions&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;POSTGRESQL.currentSchema&lt;/string&gt;&#xA;        &lt;string&gt;gen_ai&lt;/string&gt;&#xA;      &lt;/entry&gt;&#xA;    &lt;/extraOptions&gt;&#xA;    &lt;extraOptionsOrder/&gt;&#xA;    &lt;attributes&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;IS_CLUSTERED&lt;/string&gt;&#xA;        &lt;string&gt;N&lt;/string&gt;&#xA;      &lt;/entry&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;SUPPORTS_TIMESTAMP_DATA_TYPE&lt;/string&gt;&#xA;        &lt;string&gt;Y&lt;/string&gt;&#xA;      &lt;/entry&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;MSSQL_DOUBLE_DECIMAL_SEPARATOR&lt;/string&gt;&#xA;        &lt;string&gt;N&lt;/string&gt;&#xA;      &lt;/entry&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;FORCE_IDENTIFIERS_TO_LOWERCASE&lt;/string&gt;&#xA;        &lt;string&gt;N&lt;/string&gt;&#xA;      &lt;/entry&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;PRESERVE_RESERVED_WORD_CASE&lt;/string&gt;&#xA;        &lt;string&gt;Y&lt;/string&gt;&#xA;      &lt;/entry&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;FORCE_IDENTIFIERS_TO_UPPERCASE&lt;/string&gt;&#xA;        &lt;string&gt;N&lt;/string&gt;&#xA;      &lt;/entry&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;PORT_NUMBER&lt;/string&gt;&#xA;        &lt;string&gt;5432&lt;/string&gt;&#xA;      &lt;/entry&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;USE_POOLING&lt;/string&gt;&#xA;        &lt;string&gt;N&lt;/string&gt;&#xA;      &lt;/entry&gt;&#xA;      &lt;entry&gt;&#xA;        &lt;string&gt;DATABASE_