    <Dimension name="SizeBand">
      <Hierarchy hasAll="true" allMemberName="All Size Bands">
        <Level name="Size Band" type="Integer" uniqueMembers="true" levelType="Regular" hideMemberIf="Never">
          <Annotations><Annotation name="AnalyzerBusinessGroup">19. File &amp; Object Attributes</Annotation></Annotations>
          <KeyExpression>
            <SQL>
              CASE
                WHEN "Size" IS NULL THEN -1
                WHEN "Size" &lt; 100*1024 THEN 1
                WHEN "Size" &lt; 1024*1024 THEN 2
                WHEN "Size" &lt; 10*1024*1024 THEN 3
                WHEN "Size" &lt; 100*1024*1024 THEN 4
                ELSE 5
              END
            </SQL>
          </KeyExpression>
          <NameExpression>
            <SQL>
              CASE
                WHEN "Size" IS NULL THEN 'Unknown'
                WHEN "Size" &lt; 100*1024 THEN '&lt;100 KB'
                WHEN "Size" &lt; 1024*1024 THEN '100 KB–1 MB'
                WHEN "Size" &lt; 10*1024*1024 THEN '1–10 MB'
                WHEN "Size" &lt; 100*1024*1024 THEN '10–100 MB'
                ELSE '&gt;100 MB'
              END
            </SQL>
          </NameExpression>
        </Level>
      </Hierarchy>
    </Dimension>

    <Dimension name="TotalChildFileSizeBand">
      <Hierarchy hasAll="true" allMemberName="All Total Child File Size Bands">
        <Level name="Total Child File Size Band" type="Integer" uniqueMembers="true" levelType="Regular" hideMemberIf="Never">
          <Annotations><Annotation name="AnalyzerBusinessGroup">19. File &amp; Object Attributes</Annotation></Annotations>
          <KeyExpression>
            <SQL>
              CASE
                WHEN "totalchildfilesize" IS NULL THEN -1
                WHEN "totalchildfilesize" &lt; 10*1024*1024 THEN 1
                WHEN "totalchildfilesize" &lt; 100*1024*1024 THEN 2
                WHEN "totalchildfilesize" &lt; 1024*1024*1024 THEN 3
                WHEN "totalchildfilesize" &lt; 10*1024*1024*1024 THEN 4
                ELSE 5
              END
            </SQL>
          </KeyExpression>
          <NameExpression>
            <SQL>
              CASE
                WHEN "totalchildfilesize" IS NULL THEN 'Unknown'
                WHEN "totalchildfilesize" &lt; 10*1024*1024 THEN '&lt;10 MB'
                WHEN "totalchildfilesize" &lt; 100*1024*1024 THEN '10–100 MB'
                WHEN "totalchildfilesize" &lt; 1024*1024*1024 THEN '100 MB–1 GB'
                WHEN "totalchildfilesize" &lt; 10*1024*1024*1024 THEN '1–10 GB'
                ELSE '&gt;10 GB'
              END
            </SQL>
          </NameExpression>
        </Level>
      </Hierarchy>
    </Dimension>

    <Dimension name="ChildFilesBand">
      <Hierarchy hasAll="true" allMemberName="All Child Files Bands">
        <Level name="Child Files Band" type="Integer" uniqueMembers="true" levelType="Regular" hideMemberIf="Never">
          <Annotations><Annotation name="AnalyzerBusinessGroup">19. File &amp; Object Attributes</Annotation></Annotations>
          <KeyExpression>
            <SQL>
              CASE
                WHEN "childfiles" IS NULL THEN -1
                WHEN "childfiles" = 0 THEN 0
                WHEN "childfiles" &lt;= 10 THEN 1
                WHEN "childfiles" &lt;= 100 THEN 2
                WHEN "childfiles" &lt;= 1000 THEN 3
                ELSE 4
              END
            </SQL>
          </KeyExpression>
          <NameExpression>
            <SQL>
              CASE
                WHEN "childfiles" IS NULL THEN 'Unknown'
                WHEN "childfiles" = 0 THEN '0'
                WHEN "childfiles" &lt;= 10 THEN '1–10'
                WHEN "childfiles" &lt;= 100 THEN '11–100'
                WHEN "childfiles" &lt;= 1000 THEN '101–1K'
                ELSE '1K+'
              END
            </SQL>
          </NameExpression>
        </Level>
      </Hierarchy>
    </Dimension>

