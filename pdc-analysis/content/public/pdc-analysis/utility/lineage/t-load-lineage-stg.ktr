<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>t-load-lineage-stg</name>
    <description>Parse OpenLineage events JSON from PDC API page and insert into stg_lineage_event.
Called by t_PDC_get_lineage via TransExecutor (one invocation per API page).
Input: full page JSON string in field "events" (response format: {statusCode,message,data:{events:[],pageInfo:{}}}).
Connection table expansion is done in j-lineage-main via SQL CROSS JOIN LATERAL unnest().</description>
    <extended_description />
    <trans_version />
    <trans_type>Normal</trans_type>
    <trans_status>0</trans_status>
    <directory>/public/pdc-analysis/utility/lineage</directory>
    <parameters>
    </parameters>
    <log>
      <trans-log-table>
        <connection />
        <schema />
        <table />
        <size_limit_lines />
        <interval />
        <timeout_days />
        <field><id>ID_BATCH</id><enabled>Y</enabled><name>ID_BATCH</name></field>
        <field><id>CHANNEL_ID</id><enabled>Y</enabled><name>CHANNEL_ID</name></field>
        <field><id>TRANSNAME</id><enabled>Y</enabled><name>TRANSNAME</name></field>
        <field><id>STATUS</id><enabled>Y</enabled><name>STATUS</name></field>
        <field><id>LINES_READ</id><enabled>Y</enabled><name>LINES_READ</name><subject /></field>
        <field><id>LINES_WRITTEN</id><enabled>Y</enabled><name>LINES_WRITTEN</name><subject /></field>
        <field><id>LINES_UPDATED</id><enabled>Y</enabled><name>LINES_UPDATED</name><subject /></field>
        <field><id>LINES_INPUT</id><enabled>Y</enabled><name>LINES_INPUT</name><subject /></field>
        <field><id>LINES_OUTPUT</id><enabled>Y</enabled><name>LINES_OUTPUT</name><subject /></field>
        <field><id>LINES_REJECTED</id><enabled>Y</enabled><name>LINES_REJECTED</name><subject /></field>
        <field><id>ERRORS</id><enabled>Y</enabled><name>ERRORS</name></field>
        <field><id>STARTDATE</id><enabled>Y</enabled><name>STARTDATE</name></field>
        <field><id>ENDDATE</id><enabled>Y</enabled><name>ENDDATE</name></field>
        <field><id>LOGDATE</id><enabled>Y</enabled><name>LOGDATE</name></field>
        <field><id>DEPDATE</id><enabled>Y</enabled><name>DEPDATE</name></field>
        <field><id>REPLAYDATE</id><enabled>Y</enabled><name>REPLAYDATE</name></field>
        <field><id>LOG_FIELD</id><enabled>Y</enabled><name>LOG_FIELD</name></field>
        <field><id>EXECUTING_SERVER</id><enabled>N</enabled><name>EXECUTING_SERVER</name></field>
        <field><id>EXECUTING_USER</id><enabled>N</enabled><name>EXECUTING_USER</name></field>
        <field><id>CLIENT</id><enabled>N</enabled><name>CLIENT</name></field>
      </trans-log-table>
      <perf-log-table><connection /><schema /><table /><interval /><timeout_days /></perf-log-table>
      <channel-log-table><connection /><schema /><table /><timeout_days /></channel-log-table>
      <step-log-table><connection /><schema /><table /><timeout_days /></step-log-table>
      <metrics-log-table><connection /><schema /><table /><timeout_days /></metrics-log-table>
    </log>
    <maxdate><connection /><table /><field /><offset>0.0</offset><maxdiff>0.0</maxdiff></maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <capture_step_performance>N</capture_step_performance>
    <step_performance_capturing_delay>1000</step_performance_capturing_delay>
    <step_performance_capturing_size_limit>100</step_performance_capturing_size_limit>
    <dependencies></dependencies>
    <partitionschemas></partitionschemas>
    <slaveservers></slaveservers>
    <clusterschemas></clusterschemas>
    <created_user>admin</created_user>
    <created_date>2026/05/13 00:00:00.000</created_date>
    <modified_user>admin</modified_user>
    <modified_date>2026/05/13 00:00:00.000</modified_date>
    <key_for_session_key />
    <is_key_private>N</is_key_private>
  </info>
  <notepads>
  </notepads>
  <connection>
    <name>BIDB_EXT</name>
    <server>${BIDB_EXT_HOST}</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>${BIDB_EXT_DB_NAME}</database>
    <port>${BIDB_EXT_PORT}</port>
    <username>${BIDB_EXT_USERNAME}</username>
    <password>${BIDB_EXT_PASSWORD}</password>
    <servername />
    <data_tablespace />
    <index_tablespace />
    <attributes>
      <attribute><code>FORCE_IDENTIFIERS_TO_LOWERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>FORCE_IDENTIFIERS_TO_UPPERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>PORT_NUMBER</code><attribute>5432</attribute></attribute>
      <attribute><code>QUOTE_ALL_FIELDS</code><attribute>N</attribute></attribute>
      <attribute><code>SUPPORTS_BOOLEAN_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>SUPPORTS_TIMESTAMP_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>USE_POOLING</code><attribute>N</attribute></attribute>
    </attributes>
  </connection>
  <order>
    <hop><from>events</from><to>JSON parse events</to><enabled>Y</enabled></hop>
    <hop><from>JSON parse events</from><to>map fields</to><enabled>Y</enabled></hop>
    <hop><from>map fields</from><to>stg_lineage_event</to><enabled>Y</enabled></hop>
  </order>

  <!-- Step 1: Receive the full API page JSON from the parent transformation (t_PDC_get_lineage) -->
  <step>
    <name>events</name>
    <type>RowsFromResult</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning><method>none</method><schema_name /></partitioning>
    <fields>
      <field><name>events</name><type>String</type><length>-1</length><precision>-1</precision></field>
    </fields>
    <attributes />
    <cluster_schema />
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>64</xloc><yloc>112</yloc><draw>Y</draw></GUI>
  </step>

  <!-- Step 2: Parse OpenLineage JSON. One output row per event.
       API format: {statusCode, message, data:{events:[{_id, eventTime, eventType, run:{runId},
         job:{name, facets:{jobType:{integration, jobType, processingType}}},
         inputs:[{namespace, name}], outputs:[{namespace, name}]}],
         pageInfo:{hasNextPage, totalCount}}}
       inputs / outputs are extracted as raw JSON strings for processing in the JavaScript step. -->
  <step>
    <name>JSON parse events</name>
    <type>JsonInput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning><method>none</method><schema_name /></partitioning>
    <include>N</include>
    <include_field />
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <includeNulls>N</includeNulls>
    <rownum_field />
    <file></file>
    <fields>
      <!-- Scalar fields from OpenLineage event structure -->
      <field>
        <name>event_nk</name><path>$.data.events[*]._id</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <field>
        <name>event_time_str</name><path>$.data.events[*].eventTime</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <field>
        <name>event_type</name><path>$.data.events[*].eventType</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <!-- run can be null for some events — ignoreMissingPath=Y handles this -->
      <field>
        <name>run_id</name><path>$.data.events[*].run.runId</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <field>
        <name>job_name</name><path>$.data.events[*].job.name</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <field>
        <name>processing_type</name><path>$.data.events[*].job.facets.jobType.processingType</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <field>
        <name>integration</name><path>$.data.events[*].job.facets.jobType.integration</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <field>
        <name>job_type</name><path>$.data.events[*].job.facets.jobType.jobType</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <!-- First input/output namespace (most events have a single namespace per direction) -->
      <field>
        <name>in_namespace</name><path>$.data.events[*].inputs[0].namespace</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <field>
        <name>out_namespace</name><path>$.data.events[*].outputs[0].namespace</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <!-- Full inputs/outputs arrays as JSON strings — parsed into pipe-delimited lists in the JS step -->
      <field>
        <name>inputs_json</name><path>$.data.events[*].inputs</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
      <field>
        <name>outputs_json</name><path>$.data.events[*].outputs</path><type>String</type>
        <format /><currency /><decimal /><group />
        <length>-1</length><precision>-1</precision><trim_type>none</trim_type><repeat>N</repeat>
      </field>
    </fields>
    <limit>0</limit>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <valueField>events</valueField>
    <shortFileFieldName /><pathFieldName /><hiddenFieldName />
    <lastModificationTimeFieldName /><uriNameFieldName />
    <rootUriNameFieldName /><extensionFieldName /><sizeFieldName />
    <attributes />
    <cluster_schema />
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>224</xloc><yloc>112</yloc><draw>Y</draw></GUI>
  </step>

  <!-- Step 3: Derive pipe-delimited in_names/out_names from the inputs/outputs JSON arrays,
       compute counts, and parse event_time into a Date for event_date. -->
  <step>
    <name>map fields</name>
    <type>ScriptValueMod</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning><method>none</method><schema_name /></partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScript>
      <jsScript_item>
        <jsScript_itemName>map_fields</jsScript_itemName>
        <jsScript_itemType>0</jsScript_itemType>
        <jsScript_item><![CDATA[
// Parse inputs_json array and build pipe-delimited in_names + input_count
var in_names = '';
var input_count = 0;
if (inputs_json != null && inputs_json.length() > 2) {
  try {
    var arr = eval('(' + inputs_json + ')');
    if (arr && arr.length) {
      input_count = arr.length;
      for (var i = 0; i < arr.length; i++) {
        if (i > 0) in_names += '|';
        in_names += (arr[i].name != null ? arr[i].name : '');
      }
    }
  } catch(e) { /* leave in_names empty on parse error */ }
}

// Parse outputs_json array and build pipe-delimited out_names + output_count
var out_names = '';
var output_count = 0;
if (outputs_json != null && outputs_json.length() > 2) {
  try {
    var arr2 = eval('(' + outputs_json + ')');
    if (arr2 && arr2.length) {
      output_count = arr2.length;
      for (var i = 0; i < arr2.length; i++) {
        if (i > 0) out_names += '|';
        out_names += (arr2[i].name != null ? arr2[i].name : '');
      }
    }
  } catch(e) { /* leave out_names empty on parse error */ }
}

// Parse event_date from eventTime ISO string (e.g. "2026-05-07T19:08:23.61Z")
var event_date = null;
if (event_time_str != null && event_time_str.length() > 9) {
  try {
    var fmt = new java.text.SimpleDateFormat("yyyy-MM-dd");
    event_date = fmt.parse(event_time_str.substring(0, 10));
  } catch(e) { event_date = null; }
}

// Parse event_time to full timestamp
var event_time = null;
if (event_time_str != null && event_time_str.length() > 18) {
  try {
    var tsFmt = new java.text.SimpleDateFormat("yyyy-MM-dd'T'HH:mm:ss");
    event_time = tsFmt.parse(event_time_str.substring(0, 19));
  } catch(e) { event_time = null; }
}
]]>
        </jsScript_item>
      </jsScript_item>
    </jsScript>
    <fields>
      <field>
        <name>in_names</name>
        <rename>in_names</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>out_names</name>
        <rename>out_names</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>input_count</name>
        <rename>input_count</rename>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>output_count</name>
        <rename>output_count</rename>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>event_date</name>
        <rename>event_date</rename>
        <type>Date</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
      <field>
        <name>event_time</name>
        <rename>event_time</rename>
        <type>Date</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes />
    <cluster_schema />
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>400</xloc><yloc>112</yloc><draw>Y</draw></GUI>
  </step>

  <!-- Step 4: Insert into stg_lineage_event. Duplicate events (same event_nk) are rejected
       via the unique index on event_nk — set ignore_errors=Y to skip them silently. -->
  <step>
    <name>stg_lineage_event</name>
    <type>TableOutput</type>
    <description />
    <distribute>Y</distribute>
    <custom_distribution />
    <copies>1</copies>
    <partitioning><method>none</method><schema_name /></partitioning>
    <connection>BIDB_EXT</connection>
    <schema>${BIDB_EXT_SCHEMA_NAME}</schema>
    <table>stg_lineage_event</table>
    <commit>1000</commit>
    <truncate>N</truncate>
    <ignore_errors>Y</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field />
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field />
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field />
    <fields>
      <field><column_name>event_nk</column_name><stream_name>event_nk</stream_name></field>
      <field><column_name>event_time</column_name><stream_name>event_time</stream_name></field>
      <field><column_name>event_type</column_name><stream_name>event_type</stream_name></field>
      <field><column_name>run_id</column_name><stream_name>run_id</stream_name></field>
      <field><column_name>job_name</column_name><stream_name>job_name</stream_name></field>
      <field><column_name>processing_type</column_name><stream_name>processing_type</stream_name></field>
      <field><column_name>integration</column_name><stream_name>integration</stream_name></field>
      <field><column_name>job_type</column_name><stream_name>job_type</stream_name></field>
      <field><column_name>in_namespace</column_name><stream_name>in_namespace</stream_name></field>
      <field><column_name>in_names</column_name><stream_name>in_names</stream_name></field>
      <field><column_name>out_namespace</column_name><stream_name>out_namespace</stream_name></field>
      <field><column_name>out_names</column_name><stream_name>out_names</stream_name></field>
      <field><column_name>input_count</column_name><stream_name>input_count</stream_name></field>
      <field><column_name>output_count</column_name><stream_name>output_count</stream_name></field>
      <field><column_name>event_date</column_name><stream_name>event_date</stream_name></field>
    </fields>
    <attributes />
    <cluster_schema />
    <remotesteps><input></input><output></output></remotesteps>
    <GUI><xloc>576</xloc><yloc>112</yloc><draw>Y</draw></GUI>
  </step>

  <step_error_handling>
  </step_error_handling>
  <slave-step-copy-partition-distribution>
  </slave-step-copy-partition-distribution>
  <slave_transformation>N</slave_transformation>
  <attributes />
</transformation>
