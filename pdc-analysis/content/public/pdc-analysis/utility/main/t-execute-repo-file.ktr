  <step>
    <name>Split SQL</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
// Substitute ${VAR_NAME} with Kettle variable values,
// then replace statement-ending semicolons with a split
// delimiter, respecting dollar-quoted blocks.

var sql = '' + result;

// Substitute ${VAR_NAME} with Kettle variable values
var idx = 0;
while (true) {
  var start = sql.indexOf('${', idx);
  if (start &lt; 0) break;
  var end = sql.indexOf('}', start + 2);
  if (end &lt; 0) break;
  var varName = sql.substring(start + 2, end);
  var varVal = getVariable(varName, '');
  if (varVal != '') {
    sql = sql.substring(0, start) + varVal + sql.substring(end + 1);
    idx = start + varVal.length;
  } else {
    idx = end + 1;
  }
}

// Replace statement-ending semicolons with delimiter,
// but skip semicolons inside dollar-quoted blocks
var DELIM = '|||SPLIT|||';
var out = '';
var inDQ = false;
var dqTag = '';

for (var i = 0; i &lt; sql.length; i++) {
  var ch = sql.charAt(i);

  if (ch == '$' &amp;&amp; !inDQ) {
    var te = sql.indexOf('$', i + 1);
    if (te > i) {
      var cand = sql.substring(i, te + 1);
      var ok = true;
      for (var c = 1; c &lt; cand.length - 1; c++) {
        var cc = cand.charAt(c);
        if (!((cc >= 'a' &amp;&amp; cc &lt;= 'z') || (cc >= 'A' &amp;&amp; cc &lt;= 'Z') || (cc >= '0' &amp;&amp; cc &lt;= '9') || cc == '_')) {
          ok = false;
          break;
        }
      }
      if (ok) {
        dqTag = cand;
        inDQ = true;
        out += cand;
        i = te;
        continue;
      }
    }
  } else if (inDQ &amp;&amp; ch == '$') {
    if (sql.substring(i, i + dqTag.length) == dqTag) {
      out += dqTag;
      i += dqTag.length - 1;
      inDQ = false;
      continue;
    }
  }

  if (ch == ';' &amp;&amp; !inDQ) {
    out += DELIM;
  } else {
    out += ch;
  }
}

var prepared_sql = out;
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>prepared_sql</name>
        <rename>prepared_sql</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
