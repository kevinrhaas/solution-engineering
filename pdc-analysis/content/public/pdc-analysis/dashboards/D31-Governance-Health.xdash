<theme-ref>0-Ruby</theme-ref>
<layout>
<overlay xmlns:pho="http://www.pentaho.com" pho:fixie="withme">
<box id="Panel_1" pho:title="Executive KPI Snapshot" flex="1" collapsed="false" type="titled-panel"/>
<box id="Panel_2" pho:title="Governance Coverage % by Source" flex="1" collapsed="false" type="titled-panel"/>
<box id="Panel_3" pho:title="Governance Mix (Entity Count Share)" flex="1" collapsed="false" type="titled-panel"/>
<box id="Panel_4" pho:title="Governed vs Ungoverned Counts by Source" flex="1" collapsed="false" type="titled-panel"/>
<box id="Panel_5" pho:title="Missing Metadata Counts by Source" flex="1" collapsed="false" type="titled-panel"/>
<box id="Panel_6" pho:title="Metadata Completeness % by Source" flex="1" collapsed="false" type="titled-panel"/>
</overlay>
</layout>
