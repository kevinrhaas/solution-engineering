  <Cube name="PDSO_entities">
    <Table name="pdso_entities" schema="bidb_ext">
      <AggPattern pattern="agg_.*">
        <AggFactCount column="fact_count"/>
        <AggMeasure name="[Measures].[File Count]" column="filecount"/>
        <AggMeasure name="[Measures].[Size Bytes]" column="size"/>
        <AggMeasure name="[Measures].[Number of Child Directories]" column="childdirs"/>
        <AggMeasure name="[Measures].[Child Directory Size Bytes]" column="childdirsize"/>
        <AggMeasure name="[Measures].[Number of Child Files]" column="childfiles"/>
        <AggMeasure name="[Measures].[Child File Size Bytes]" column="childfilesize"/>
        <AggMeasure name="[Measures].[Total Number of Child Directories]" column="totalchilddirs"/>
        <AggMeasure name="[Measures].[Total Child Directory Size Bytes]" column="totalchilddirsize"/>
        <AggMeasure name="[Measures].[Total Number of Child Files]" column="totalchildfiles"/>
        <AggMeasure name="[Measures].[Total Child File Size Bytes]" column="totalchildfilesize"/>
        <AggLevel name="[Name].[Name]" column="Name"/>
        <AggLevel name="[Type].[Type]" column="Type"/>
        <AggLevel name="[Parent].[Parent]" column="parent"/>
        <AggLevel name="[Resource Type].[Resource Type]" column="resourcetype"/>
        <AggLevel name="[Data Source Name].[Data Source Name]" column="datasourcename"/>
        <AggLevel name="[Data Source Type].[Data Source Type]" column="datasourcetype"/>
        <AggLevel name="[Term Name].[Term Name]" column="termname"/>
        <AggLevel name="[Modified Age Months].[Modified Age Months]" column="modified_age_months"/>
        <AggLevel name="[Modified Age Years].[Modified Age Years]" column="modified_age_years"/>
        <AggLevel name="[Path Type].[Path Type]" column="pathtype"/>
        <AggLevel name="[File Extension].[File Extension]" column="fileextension"/>
        <AggLevel name="[File Type].[File Type]" column="filetype"/>
        <AggLevel name="[Parent Path].[Parent Path]" column="parentpath"/>
      </AggPattern>
    </Table>
