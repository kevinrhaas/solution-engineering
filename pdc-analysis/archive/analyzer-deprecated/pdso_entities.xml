    <!-- ============================================ -->
    <!-- MEASURES - ORGANIZED BY CATEGORY -->
    <!-- ============================================ -->
    
    <!-- Volume Metrics -->
    <Measure name="File Count" column="filecount" aggregator="sum" caption="Number of Objects" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">11. Volume Metrics</Annotation></Annotations>
    </Measure>
    
    <!-- Size Metrics (Primary) -->
    <Measure name="Size Bytes" column="Size" aggregator="sum" caption="Size Bytes" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">12. Size Metrics - Primary</Annotation></Annotations>
    </Measure>
    
    <!-- Child Container Metrics -->
    <Measure name="Number of Child Directories" aggregator="sum" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
      <MeasureExpression><SQL>CAST(COALESCE(childdirs, '0') AS NUMERIC)</SQL></MeasureExpression>
    </Measure>
    <Measure name="Child Directory Size Bytes" aggregator="sum" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
      <MeasureExpression><SQL>CAST(COALESCE(childdirsize, '0') AS NUMERIC)</SQL></MeasureExpression>
    </Measure>
    <Measure name="Number of Child Files" aggregator="sum" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
      <MeasureExpression><SQL>CAST(COALESCE(childfiles, '0') AS NUMERIC)</SQL></MeasureExpression>
    </Measure>
    <Measure name="Child File Size Bytes" aggregator="sum" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
      <MeasureExpression><SQL>CAST(COALESCE(childfilesize, '0') AS NUMERIC)</SQL></MeasureExpression>
    </Measure>
    
    <!-- Total Child Metrics -->
    <Measure name="Total Number of Child Directories" aggregator="sum" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
      <MeasureExpression><SQL>CAST(COALESCE(totalchilddirs, '0') AS NUMERIC)</SQL></MeasureExpression>
    </Measure>
    <Measure name="Total Child Directory Size Bytes" aggregator="sum" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
      <MeasureExpression><SQL>CAST(COALESCE(totalchilddirsize, '0') AS NUMERIC)</SQL></MeasureExpression>
    </Measure>
    <Measure name="Total Number of Child Files" aggregator="sum" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
      <MeasureExpression><SQL>CAST(COALESCE(totalchildfiles, '0') AS NUMERIC)</SQL></MeasureExpression>
    </Measure>
    <Measure name="Total Child File Size Bytes" aggregator="sum" formatString="#,###">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
      <MeasureExpression><SQL>CAST(COALESCE(totalchildfilesize, '0') AS NUMERIC)</SQL></MeasureExpression>
    </Measure>
    
    <!-- ============================================ -->
    <!-- CALCULATED MEASURES - Size Conversions -->
    <!-- ============================================ -->
    
    <CalculatedMember name="Size GB" dimension="Measures" formula="[Measures].[Size Bytes] / 1073741824" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">12. Size Metrics - Primary</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Size TB" dimension="Measures" formula="[Measures].[Size Bytes] / 1099511627776" formatString="#,###.000">
      <Annotations><Annotation name="AnalyzerBusinessGroup">12. Size Metrics - Primary</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Average Object Size Bytes" dimension="Measures" formula="IIF([Measures].[File Count] = 0, 0, [Measures].[Size Bytes] / [Measures].[File Count])" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">12. Size Metrics - Primary</Annotation></Annotations>
    </CalculatedMember>
    
    <!-- Child Directory Size Conversions -->
    <CalculatedMember name="Child Directory Size GB" dimension="Measures" formula="[Measures].[Child Directory Size Bytes] / 1073741824" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Child Directory Size TB" dimension="Measures" formula="[Measures].[Child Directory Size Bytes] / 1099511627776" formatString="#,###.000">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Average Child Directory Size Bytes" dimension="Measures" formula="IIF([Measures].[Number of Child Directories] = 0, 0, [Measures].[Child Directory Size Bytes] / [Measures].[Number of Child Directories])" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
    </CalculatedMember>
    
    <!-- Child File Size Conversions -->
    <CalculatedMember name="Child File Size GB" dimension="Measures" formula="[Measures].[Child File Size Bytes] / 1073741824" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Child File Size TB" dimension="Measures" formula="[Measures].[Child File Size Bytes] / 1099511627776" formatString="#,###.000">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Average Child File Size Bytes" dimension="Measures" formula="IIF([Measures].[Number of Child Files] = 0, 0, [Measures].[Child File Size Bytes] / [Measures].[Number of Child Files])" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">13. Child Container Metrics</Annotation></Annotations>
    </CalculatedMember>
    
    <!-- Total Child Directory Size Conversions -->
    <CalculatedMember name="Total Child Directory Size GB" dimension="Measures" formula="[Measures].[Total Child Directory Size Bytes] / 1073741824" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Total Child Directory Size TB" dimension="Measures" formula="[Measures].[Total Child Directory Size Bytes] / 1099511627776" formatString="#,###.000">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Average Total Child Directory Size Bytes" dimension="Measures" formula="IIF([Measures].[Total Number of Child Directories] = 0, 0, [Measures].[Total Child Directory Size Bytes] / [Measures].[Total Number of Child Directories])" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
    </CalculatedMember>
    
    <!-- Total Child File Size Conversions -->
    <CalculatedMember name="Total Child File Size GB" dimension="Measures" formula="[Measures].[Total Child File Size Bytes] / 1073741824" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Total Child File Size TB" dimension="Measures" formula="[Measures].[Total Child File Size Bytes] / 1099511627776" formatString="#,###.000">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
    </CalculatedMember>
    <CalculatedMember name="Average Total Child File Size Bytes" dimension="Measures" formula="IIF([Measures].[Total Number of Child Files] = 0, 0, [Measures].[Total Child File Size Bytes] / [Measures].[Total Number of Child Files])" formatString="#,###.00">
      <Annotations><Annotation name="AnalyzerBusinessGroup">14. Total Child Metrics</Annotation></Annotations>
    </CalculatedMember>
    
    <!-- ============================================ -->
    <!-- CALCULATED MEASURES - Environmental Impact -->
    <!-- ============================================ -->
    
    <CalculatedMember name="Estimated CO2e (Metric Tons/Year)" dimension="Measures" formula="[Measures].[Size TB] * 0.35" formatString="#,###.00">
      <Annotations>
        <Annotation name="AnalyzerBusinessGroup">15. Environmental Impact</Annotation>
        <Annotation name="Description">Estimated annual CO2 emissions in metric tons based on industry standard of 0.35 metric tons CO2e per TB per year for data storage</Annotation>
      </Annotations>
    </CalculatedMember>

    <!-- ============================================ -->
    <!-- CALCULATED MEASURES - Previous Period -->
    <!-- ============================================ -->

    <CalculatedMember name="Size TB (Previous Year)" dimension="Measures">
      <Annotations><Annotation name="AnalyzerBusinessGroup">12. Size Metrics - Primary</Annotation></Annotations>
      <Formula>
        ([Measures].[Size TB], ParallelPeriod([Modified Date].[Year], 1))
      </Formula>
    </CalculatedMember>

    <CalculatedMember name="Size TB YoY Change" dimension="Measures">
      <Annotations><Annotation name="AnalyzerBusinessGroup">12. Size Metrics - Primary</Annotation></Annotations>
      <Formula>
        [Measures].[Size TB] - [Measures].[Size TB (Previous Year)]
      </Formula>
    </CalculatedMember>

    <CalculatedMember name="Size TB YoY % Change" dimension="Measures" formatString="#,##0.00%">
      <Annotations><Annotation name="AnalyzerBusinessGroup">12. Size Metrics - Primary</Annotation></Annotations>
      <Formula>
        IIF(
          IsEmpty([Measures].[Size TB (Previous Year)]) OR [Measures].[Size TB (Previous Year)] = 0,
          NULL,
          ([Measures].[Size TB] - [Measures].[Size TB (Previous Year)]) / [Measures].[Size TB (Previous Year)]
        )
      </Formula>
    </CalculatedMember>


