    <report catalog="PDSO_entities" cube="PDSO_entities" reportTypeEnum="PIVOT" showRowGrandTotal="true" showColumnGrandTotal="true" totalsOnTopLeft="false" useNonVisualTotals="false" showEmptyEnum="SHOW_MEASURE" emptyCellDisplay="-" showDrillLinks="false" version="15" autoRefresh="true" freezeColumns="false" freezeRows="false">
        <measures>
