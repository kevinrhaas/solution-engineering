    <connection>BIDB</connection>
    <sql>SELECT
  emv._id
, emv."Name"
, emv."Type"
, emv."Parent"
, emv."ResourceType"
, emv."DataSourceId"
, emv."DataSourceName"
, emv."DataSourceType"
, cast (emv."LastUpdate" as VARCHAR)
, cast (emv."Url" as VARCHAR)
, cast (emv."ParentName" as VARCHAR)
, cast (emv."LastUpdateStatistics" as VARCHAR)
, cast (emv."Path" as VARCHAR)
, cast (emv."ParentPath" as VARCHAR)
, cast (emv."PathType" as VARCHAR)
, cast (emv."FileExtension" as VARCHAR)
, cast (emv."Size" as INTEGER)
, cast (emv."Flags" as VARCHAR)
, cast (emv."Owner" as VARCHAR)
, cast (emv."Group" as VARCHAR)
, cast (emv."SymLinkTarget" as VARCHAR)
, cast (emv."FileType" as VARCHAR)
, cast (emv."CreatedAt" as VARCHAR)
, cast (emv."ModifiedAt" as VARCHAR)
, cast (emv."AccessedAt" as VARCHAR)
, cast (emv."ScannedAt" as VARCHAR)
, cast (emv."IsSymlink" as VARCHAR)
, cast (emv."LinkType" as VARCHAR)
, cast (emv."PhysicalLocation" as VARCHAR)
, emv."ChildDirs"
, emv."ChildFiles"
, emv."ChildDirSize"
, emv."ChildFileSize"
, emv."TotalChildDirs"
, emv."TotalChildFiles"
, emv."TotalChildDirSize"
, emv."TotalChildFileSize"
, cast (emv."FqdnDisplay" as VARCHAR)
, cast (tv."TermName" as VARCHAR)
FROM "public".entities_master_view as emv LEFT OUTER JOIN "public".terms_view as tv on emv."FqdnDisplay" = tv."FqdnDisplay"

</sql>
